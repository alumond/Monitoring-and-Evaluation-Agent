# Google Sheets service account and workbook
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Gemini
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
GEMINI_API_KEY=your_gemini_api_key_here

# Email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_or_app_password_here
EMAIL_FROM=your_email@example.com
EMAIL_TO=stakeholder1@example.com,stakeholder2@example.com

# Project and report settings
PROJECT_NAME=Monitoring & Evaluation Intelligence Program
BRAND_LOGO_PATH=./assets/logo.png
REPORT_FILENAME_TEMPLATE=me_report_{timestamp}.pdf
REPORT_SUBJECT_FORMAT=M&E Report - {project_name} - {period}

# Escalation workflow settings
ESCALATION_ENABLED=true
ESCALATION_EMAIL_TO=ops.team@example.com,program.manager@example.com
ESCALATION_KPI_THRESHOLD=90.0
ESCALATION_SUBJECT_FORMAT=Escalation Alert - {project_name} - {period}
ESCALATION_MESSAGE_TEMPLATE=Escalation detected for {project_name}. Review the operational action summary below.

# Audit log database
LOG_DB_URL=sqlite:///./db/report_audit.db
